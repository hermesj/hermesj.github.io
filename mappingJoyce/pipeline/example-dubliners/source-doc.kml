			</Point>
		</Placemark>
		<Placemark>
			<name>Henry Street</name>
			<description><![CDATA["Clay"<br>[where Maria buys plumcake]<br>"She decided to buy some plumcake but Downes's plumcake had not enough 
almond icing on top of it so she went over to a shop in Henry Street" (102).<br>]]></description>
			<styleUrl>#m_ylw-pushpin00</styleUrl>
			<Point>
				<coordinates>-6.261541999999999,53.349644,0</coordinates>
			</Point>
		</Placemark>
		<Placemark>
			<name>&quot;Clay&quot; Route</name>
			<description><![CDATA[<div dir="ltr">The route Maria travels to visit Joe.<br><br>(end route according to Gifford)</div>]]></description>
			<styleUrl>#msn_ylw-pushpin</styleUrl>
			<LineString>
				<tessellate>1</tessellate>
				<coordinates>
					-6.232288801250125,53.3286122053877,0 -6.232106804719928,53.32860727824148,0 -6.231953106574847,53.32881457368973,0 -6.231866012764024,53.32940324055094,0 -6.232386819414999,53.32972817635629,0 -6.23449196468867,53.33146742598118,0 -6.235130274966044,53.33198299654617,0 -6.237279642204135,53.33501104668937,0 -6.237876965118176,53.33577762049573,0 -6.238135877644315,53.33612908062868,0 -6.240170491021453,53.33750549982186,0 -6.25075091121039,53.34118726081383,0 -6.250154667550555,53.34186174842312,0 -6.250528285809576,53.34200985612699,0 -6.249745584414988,53.34356230655808,0 -6.249305577217471,53.34409935247022,0 -6.250931602212581,53.34448370093234,0 -6.251852717136625,53.34465864062835,0 -6.25429408150679,53.34509806701642,0 -6.256826039826367,53.34569887479089,0 -6.258748525123434,53.34692520355656,0 -6.258927935851698,53.34706038557993,0 -6.25904672883367,53.3473369219554,0 -6.259286274762692,53.34766198910272,0 -6.260254,53.34977,0 -6.259301999999999,53.349968,0 -6.261714,53.349525,0 -6.260297,53.34984600000001,0 -6.261245,53.352528,0 -6.265275400470564,53.3560560005461,0 -6.263838687729458,53.35752718315823,0 -6.26193793793413,53.35917538844979,0 -6.259460000000001,53.361748,0 -6.260767000000001,53.362072,0 -6.260893000000001,53.36210299999999,0 -6.261013,53.36212900000001,0 -6.261306,53.362194,0 -6.261370000000001,53.362209,0 -6.261856578852518,53.36231871518378,0 
