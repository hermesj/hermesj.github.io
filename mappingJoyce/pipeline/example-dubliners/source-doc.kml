			<Point>
				<coordinates>-8.990035000000001,53.572918,0</coordinates>
			</Point>
		</Placemark>
		<Placemark>
			<name>France</name>
			<description><![CDATA["The Dead"<br>[where Gabriel vacations]<br>"--Well, we usually go to France or Belgium or perhaps Germany, said Gabriel awkwardly" (189).<br>]]></description>
			<LookAt>
				<longitude>5.39042599070619</longitude>
